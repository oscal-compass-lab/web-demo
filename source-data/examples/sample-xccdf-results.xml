  <cdf:status date="2024-01-15">accepted</cdf:status>
  <cdf:title>Guide to the Secure Configuration of Red Hat Enterprise Linux 9</cdf:title>
  <cdf:description>
    This guide presents a catalog of security-relevant configuration settings for Red Hat
    Enterprise Linux 9. It is a rendering of content structured in the eXtensible
    Configuration Checklist Description Format (XCCDF) in order to support security
    automation.
  </cdf:description>
  <cdf:notice id="terms-of-use" xml:lang="en-US">
    Do not attempt to implement any of the settings in this guide without first testing
    them in a non-operational environment.
  </cdf:notice>
  <cdf:reference href="https://www.nist.gov">
    <dc:publisher>NIST</dc:publisher>
    <dc:source>NIST SP 800-53</dc:source>
  </cdf:reference>
